{
  "name": "@dynatrace/backstage-plugin-dql",
  "version": "2.8.0",
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.esm.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "./alpha": {
        "backstage": "@backstage/FrontendPlugin",
        "import": "./dist/alpha.esm.js",
        "types": "./dist/alpha.d.ts",
        "default": "./dist/alpha.esm.js"
      },
      "./package.json": "./package.json"
    }
  },
  "typesVersions": {
    "*": {
      "alpha": [
        "dist/alpha.d.ts"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dynatrace/backstage-plugin.git",
    "directory": "plugins\\dql"
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "dql",
    "pluginPackages": [
      "@dynatrace/backstage-plugin-dql",
      "@dynatrace/backstage-plugin-dql-backend",
      "@dynatrace/backstage-plugin-dql-common"
    ],
    "features": {
      "./alpha": "@backstage/FrontendPlugin"
    }
  },
  "sideEffects": false,
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/catalog-model": "^1.8.0",
    "@backstage/core-compat-api": "^0.5.10",
    "@backstage/core-components": "^0.18.9",
    "@backstage/core-plugin-api": "^1.12.5",
    "@backstage/errors": "^1.3.0",
    "@backstage/frontend-plugin-api": "^0.16.2",
    "@backstage/plugin-catalog-react": "^2.1.4",
    "@backstage/theme": "^0.7.3",
    "@dynatrace/backstage-plugin-dql-common": "^2.8.0",
    "@material-ui/core": "^4.12.2",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "4.0.0-alpha.61",
    "lodash": ">=4.18.1",
    "react-use": "^17.2.4",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.1",
    "@backstage/core-app-api": "^1.20.0",
    "@backstage/dev-utils": "^1.1.22",
    "@backstage/frontend-test-utils": "^0.4.5",
    "@backstage/test-utils": "^1.7.17",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.0.0",
    "@types/lodash": "^4.17.0"
  },
  "files": [
    "dist"
  ]
}
